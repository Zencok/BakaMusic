{
  "name": "bakamusic",
  "productName": "BakaMusic",
  "version": "1.0.0",
  "description": "一个插件化、定制化、无广告的免费音乐播放器。",
  "main": ".webpack/main",
  "engines": {
    "node": "^24.15.0"
  },
  "scripts": {
    "clean": "rimraf .webpack out tmp",
    "test": "npm run test:theme-contract && npm run test:music-quality-metadata && npm run test:listening-statistics && npm run test:phase4-data && npm run test:lyric-window-z-order && npm run test:lyric-duet && npm run test:update-flow && npm run test:app-config && npm run test:file-naming && npm run test:download-lyric-export && npm run test:runtime-performance && npm run test:phase3-network && npm run test:service-manager && npm run test:startup-performance && npm run test:playback-boundary && npm run test:search-matching && npm run test:pitch-shift && npm run test:phase5-security && npm run test:phase6-governance && npm run test:runtime-packaging && npm run test:toolchain",
    "start": "chcp 65001 >nul 2>&1 & cross-env NODE_ENV=development electron-forge start",
    "dev": "chcp 65001 >nul 2>&1 & cross-env NODE_ENV=development electron-forge start --inspect-electron",
    "package": "cross-env NODE_ENV=production electron-forge package",
    "smoke:package": "node scripts/package-security-smoke.cjs && node scripts/package-smoke.cjs",
    "smoke:native": "node scripts/native-smoke.cjs --electron",
    "smoke:phase4": "node scripts/phase4-migration-smoke.cjs",
    "make": "cross-env NODE_ENV=production electron-forge make",
    "publish": "cross-env NODE_ENV=production electron-forge publish",
    "lint": "eslint ./src --fix",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "build:native": "node scripts/build-native.js",
    "sbom": "cyclonedx-npm --package-lock-only --omit dev --output-reproducible --spec-version 1.6 --validate",
    "test:theme-contract": "node -r ts-node/register scripts/theme-contract.test.cjs",
    "test:music-quality-metadata": "node -r ts-node/register/transpile-only scripts/music-quality-metadata.test.cjs",
    "test:listening-statistics": "node -r ts-node/register/transpile-only scripts/listening-statistics.test.cjs",
    "test:phase4-data": "node -r ts-node/register/transpile-only scripts/phase4-data.test.cjs",
    "test:lyric-window-z-order": "node -r ts-node/register/transpile-only scripts/lyric-window-z-order.test.cjs",
    "test:lyric-duet": "node -r ts-node/register/transpile-only scripts/lyric-duet.test.cjs",
    "test:update-flow": "node -r ts-node/register/transpile-only scripts/update-flow.test.cjs",
    "test:app-config": "node -r ts-node/register/transpile-only scripts/app-config.test.cjs",
    "test:file-naming": "node -r ts-node/register/transpile-only scripts/file-naming-formatter.test.cjs",
    "test:download-lyric-export": "node -r ts-node/register/transpile-only scripts/download-postprocess-lyric.test.cjs",
    "test:runtime-performance": "node -r ts-node/register/transpile-only scripts/runtime-performance.test.cjs",
    "test:phase3-network": "node -r ts-node/register/transpile-only scripts/phase3-network.test.cjs",
    "test:service-manager": "node scripts/service-manager.test.cjs",
    "test:startup-performance": "node scripts/startup-performance.test.cjs",
    "test:playback-boundary": "node -r ts-node/register/transpile-only scripts/playback-boundary.test.cjs",
    "test:search-matching": "node -r ts-node/register/transpile-only scripts/search-matching.test.cjs",
    "test:pitch-shift": "node -r ts-node/register/transpile-only scripts/pitch-shift.test.cjs",
    "test:phase5-security": "node scripts/phase5-electron-security.test.cjs",
    "test:phase6-governance": "node scripts/phase6-governance.test.cjs",
    "test:runtime-packaging": "node -r ts-node/register/transpile-only scripts/runtime-packaging.test.cjs",
    "test:toolchain": "node scripts/toolchain.test.cjs"
  },
  "keywords": [],
  "author": {
    "name": "Zencok",
    "email": "zencok@users.noreply.github.com"
  },
  "license": "AGPL-3.0-only",
  "lint-staged": {
    "src/**/*.{ts,tsx,js}": "eslint --fix"
  },
