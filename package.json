{
  "name": "bakamusic",
  "productName": "BakaMusic",
  "version": "1.0.0",
  "description": "一个插件化、定制化、无广告的免费音乐播放器。",
  "main": ".webpack/main",
  "scripts": {
    "start": "chcp 65001 >nul 2>&1 & electron-forge start",
    "dev": "chcp 65001 >nul 2>&1 & electron-forge start --inspect-electron",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint ./src --fix",
    "lint-staged": "lint-staged",
    "prepare": "husky install",
    "postinstall": "node scripts/patch-node-gyp.js",
    "build:native": "cd native/qmc2 && npx node-gyp rebuild && mkdir -p ../../res/.service/native && cp build/Release/qmc2.node ../../res/.service/native/qmc2.node"
  },
  "keywords": [],
  "author": {
    "name": "Zencok",
    "email": "zencok@users.noreply.github.com"
  },
  "license": "GPL",
  "lint-staged": {
    "src/**/*.{ts,tsx,js}": [
      "npm run lint",
      "git add ."
    ]
  },
